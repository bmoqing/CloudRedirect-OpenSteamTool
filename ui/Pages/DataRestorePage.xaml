<Page x:Class="CloudRedirect.Pages.DataRestorePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:res="clr-namespace:CloudRedirect.Resources"
      ScrollViewer.CanContentScroll="False">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24">
        <StackPanel MaxWidth="860">
            <DockPanel Margin="0,0,0,20">
                <ui:Button DockPanel.Dock="Right"
                           Content="{res:Loc DataRestore_Refresh}"
                           Icon="{ui:SymbolIcon ArrowSync24}"
                           Click="Refresh_Click" />
                <StackPanel>
                    <TextBlock Text="{res:Loc DataRestore_Title}"
                               FontSize="28"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                    <TextBlock Text="{res:Loc DataRestore_Subtitle}"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </DockPanel>

            <ui:CardControl Margin="0,0,0,8">
                <ui:CardControl.Header>
                    <StackPanel>
                        <TextBlock Text="{res:Loc DataRestore_CurrentAccount}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                        <TextBlock x:Name="CurrentAccountText"
                                   Text="{res:Loc DataRestore_Detecting}"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </ui:CardControl.Header>
                <ui:SymbolIcon x:Name="CurrentAccountIcon" Symbol="Person24" FontSize="24" />
            </ui:CardControl>

            <ui:CardControl Margin="0,0,0,20">
                <ui:CardControl.Header>
                    <StackPanel>
                        <TextBlock Text="{res:Loc DataRestore_Source}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                        <TextBlock x:Name="SourceText"
                                   Text="{res:Loc DataRestore_Detecting}"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap" />
                        <TextBlock x:Name="SourceCountsText"
                                   Text=""
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,4,0,0" />
                    </StackPanel>
                </ui:CardControl.Header>
                <ui:SymbolIcon x:Name="SourceIcon" Symbol="Cloud24" FontSize="24" />
            </ui:CardControl>

            <UniformGrid Columns="1" Margin="0,0,0,16">
                <ui:CardControl Margin="0,0,0,8">
                    <ui:CardControl.Header>
                        <StackPanel>
                            <TextBlock Text="{res:Loc DataRestore_PlaytimeTitle}"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                            <TextBlock Text="{res:Loc DataRestore_PlaytimeHint}"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </ui:CardControl.Header>
                    <ui:Button x:Name="RestorePlaytimeButton"
                               Content="{res:Loc DataRestore_RestorePlaytime}"
                               Icon="{ui:SymbolIcon ArrowSync24}"
                               Appearance="Primary"
                               Click="RestorePlaytime_Click" />
                </ui:CardControl>

                <ui:CardControl Margin="0,0,0,8">
                    <ui:CardControl.Header>
                        <StackPanel>
                            <TextBlock Text="{res:Loc DataRestore_StatsTitle}"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                            <TextBlock Text="{res:Loc DataRestore_StatsHint}"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </ui:CardControl.Header>
                    <ui:Button x:Name="RestoreStatsButton"
                               Content="{res:Loc DataRestore_RestoreStats}"
                               Icon="{ui:SymbolIcon Document24}"
                               Appearance="Primary"
                               Click="RestoreStats_Click" />
                </ui:CardControl>

                <ui:CardControl Margin="0,0,0,8">
                    <ui:CardControl.Header>
                        <StackPanel>
                            <TextBlock Text="{res:Loc DataRestore_LuaTitle}"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                            <TextBlock Text="{res:Loc DataRestore_LuaHint}"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </ui:CardControl.Header>
                    <ui:Button x:Name="RestoreLuaButton"
                               Content="{res:Loc DataRestore_RestoreLua}"
                               Icon="{ui:SymbolIcon Wrench24}"
                               Appearance="Primary"
                               Click="RestoreLua_Click" />
                </ui:CardControl>

                <ui:CardControl Margin="0,0,0,8">
                    <ui:CardControl.Header>
                        <StackPanel>
                            <TextBlock Text="{res:Loc ForceUpload_Title}"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                            <TextBlock Text="{res:Loc ForceUpload_Hint}"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap" />
                            <ui:TextBox x:Name="ForceUploadAppIdBox"
                                        Margin="0,10,0,0"
                                        MinWidth="220"
                                        HorizontalAlignment="Left"
                                        PlaceholderText="{res:Loc ForceUpload_AppIdTooltip}"
                                        ToolTip="{res:Loc ForceUpload_AppIdTooltip}" />
                        </StackPanel>
                    </ui:CardControl.Header>
                    <ui:Button x:Name="ForceUploadButton"
                               Content="{res:Loc ForceUpload_Button}"
                               Icon="{ui:SymbolIcon CloudArrowUp24}"
                               Appearance="Primary"
                               Click="ForceUpload_Click" />
                </ui:CardControl>
            </UniformGrid>

            <TextBlock Text="{res:Loc DataRestore_Result}"
                       FontSize="20"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                       Margin="0,0,0,12" />

            <Border Background="{DynamicResource ControlFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="12"
                    MinHeight="140"
                    MaxHeight="300">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <TextBox x:Name="ResultOutput"
                             FontFamily="Cascadia Mono,Consolas,monospace"
                             FontSize="12"
                             Text="{res:Loc DataRestore_Ready}"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                </ScrollViewer>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
